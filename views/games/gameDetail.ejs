<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0"
		/>
		<title>Document</title>
        <link rel="stylesheet" href="/css/reset.css">
        <link rel="stylesheet" href="/css/gameDetail.css">
	</head>
	<body>
        <%- include('../partials/navigation')%>

        <div class="container">
            <h1>Details</h1>
        <form method="POST" action="/games/edit/<% game.id %>">
            <div class="detailsContainer">
                <label for="title">Title: </label>
                <input type="text" name="title" id="title" value=<%= game.title%>  />
                <label for="release_year">Release Year: </label>
                <input
                    value=<%=game.release_year%> 
                    type="number"
                    name="release_year"
                    id="release_year"
                />
                <label for="price">Price: </label>
                <input type="number" name="price" id="price" step="0.01"
                value=<%=game.price%> />
                
                <div class="genresCheckboxContainer">
                    <label for="genres">Genres: </label>
                    <% genres.forEach((genre) => { %>
                        <div>
                            <input type="checkbox" name="genres" value="<%= genre.name %>" id="<%= genre.id %>"
                            
                            <%= game.genres.includes(genre.name) ? 'checked' : '' %>>
                            <label for="<%= genre.id %>"><%= genre.name %></label>
                            
                        </div>
                    
                <% }) %>

			</div>
			
			<button type="submit">Submit</button>

            </div>

            
			
		</form>
        </div>

		
	</body>
</html>
