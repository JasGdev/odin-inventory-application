<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/reset.css">
    <link rel="stylesheet" href="/css/genres.css">
</head>
<body>
    

    <%- include('../partials/navigation')%>
    <div class="container">

	<div class="genresContainer">
		<h1>Genres: </h1>	
		
		<% genres.forEach((genre) => { %>
			<div class="genreItemContainer">
				<form method="POST" action="/genres/edit/<%= genre.id %>">
					<div class="genreItem">
						<input type="text" name="name" value = <%=  genre.name %>>
						<button>Submit</button>
					</div>
				</form>
			<form method="POST" action="/genres/delete/<%= genre.id %>">
						<button type="submit">X</button>
					</form>
			</div>
			
			
		<% }) %>
	</div>




					
    <h3>Add Genre:</h3>
		<form method="POST" action="/genres/new" >
			<label for="genre">Genre: </label>
			<input type="text" name="genre" id="genre" />
			<button type="submit">Add</button>
		</form>    
    </div>

    
				
</body>
</html>